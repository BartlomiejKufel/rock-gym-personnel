<Window x:Class="RockGym.Views.FingerprintScannerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RockGym.Views"
        xmlns:services="clr-namespace:RockGym.Services"
        mc:Ignorable="d"
        Title="Skaner Odcisków Palców" 
        Height="720" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#111622"
        Foreground="White">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <services:ByteToImageConverter x:Key="ByteToImageConverter"/>

        <!-- Style dla przycisków w oknie -->
        <Style x:Key="ScannerButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                Padding="15,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ScannerButton}">
            <Setter Property="Background" Value="#FF7F3F"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF945B"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ScannerButton}">
            <Setter Property="Background" Value="#2D3748"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A5568"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Nagłówek i przycisk wczytania -->
            <RowDefinition Height="280"/> <!-- Próbka odcisku -->
            <RowDefinition Height="*"/>    <!-- Szczegóły pasującego klienta -->
            <RowDefinition Height="Auto"/> <!-- Przyciski na dole -->
        </Grid.RowDefinitions>

        <!-- 1. Nagłówek i przycisk wczytywania próbki -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Skaner Odcisków Palców" FontSize="18" FontWeight="Bold" Foreground="#FF7F3F" FontFamily="Segoe UI"/>
                <TextBlock Text="Wgraj obraz próbki linii papilarnych, aby rozpoznać" FontSize="11" Foreground="#88FFFFFF" FontFamily="Segoe UI" Margin="0,2,0,0"/>
            </StackPanel>
            
            <Button x:Name="UploadSampleButton"
                    Grid.Column="1"
                    Content="Wgraj próbkę..."
                    Style="{StaticResource PrimaryButton}"
                    Width="130"
                    VerticalAlignment="Center"
                    Click="UploadSampleButton_Click"/>
        </Grid>

        <!-- 2. Kontener podglądu odcisku palca -->
        <Border Grid.Row="1" Background="#1A1F26" CornerRadius="8" BorderBrush="#2D3748" BorderThickness="2" ClipToBounds="True">
            <Grid>
                <!-- Znak wodny / tło, gdy brak odcisku -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="👆" FontSize="48" HorizontalAlignment="Center" Opacity="0.15"/>
                    <TextBlock Text="Brak załadowanej próbki" Foreground="#44FFFFFF" FontSize="12" FontFamily="Segoe UI" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FingerprintPreview}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                </StackPanel>

                <!-- Obrazek odcisku -->
                <Image x:Name="FingerprintImage" 
                       Source="{Binding FingerprintPreview, Converter={StaticResource ByteToImageConverter}}" 
                       Stretch="Uniform" 
                       Margin="25"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <!-- Celownik skanera odcisków -->
                <Grid x:Name="ScannerTarget">
                    <Border BorderBrush="#55FF7F3F" BorderThickness="1.5" Margin="50" CornerRadius="10">
                        <Grid>
                            <!-- Narożniki celownika -->
                            <Path Data="M0,15 L0,0 L15,0" Stroke="#FF7F3F" StrokeThickness="3.5" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            <Path Data="M0,0 L15,0 L15,15" Stroke="#FF7F3F" StrokeThickness="3.5" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,-2,0"/>
                            <Path Data="M0,15 L0,0 L15,0" Stroke="#FF7F3F" StrokeThickness="3.5" HorizontalAlignment="Left" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                     <ScaleTransform ScaleY="-1"/>
                                </Path.RenderTransform>
                            </Path>
                            <Path Data="M0,0 L15,0 L15,15" Stroke="#FF7F3F" StrokeThickness="3.5" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-2,0" RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <ScaleTransform ScaleY="-1"/>
                                </Path.RenderTransform>
                            </Path>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Pasek wskaźnika prawdopodobieństwa w lewym górnym rogu podglądu -->
                <Border Background="#CC111622" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10">
                    <TextBlock Text="{Binding MatchProbabilityText, FallbackValue='Oczekiwanie...'}" 
                               Foreground="{Binding MatchProbabilityColor}" 
                               FontSize="11" 
                               FontWeight="Bold" 
                               FontFamily="Segoe UI"/>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MatchProbabilityText}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
            </Grid>
        </Border>

        <!-- 3. Szczegóły klienta -->
        <Grid Grid.Row="2" Margin="0,15,0,15">
            <!-- Pusta karta przed dopasowaniem -->
            <Border x:Name="EmptyCard" Background="#1A1F26" BorderBrush="#2D3748" BorderThickness="1.5" CornerRadius="8" Padding="20" Visibility="{Binding EmptyCardVisibility}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="🔍" FontSize="36" HorizontalAlignment="Center"/>
                    <TextBlock Text="Oczekiwanie na analizę..." Foreground="#A0AEC0" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,10,0,0" FontFamily="Segoe UI"/>
                    <TextBlock Text="Wgraj plik graficzny z próbką odcisków klienta" Foreground="#60FFFFFF" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0" FontFamily="Segoe UI" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Karta Klienta (po dopasowaniu) -->
            <Border x:Name="ClientCard" Background="#1A1F26" BorderBrush="#2D3748" BorderThickness="1.5" CornerRadius="8" Padding="15" Visibility="{Binding ClientCardVisibility}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Avatar, imię, rola, status -->
                        <RowDefinition Height="Auto"/> <!-- Separator -->
                        <RowDefinition Height="*"/>    <!-- Oferty / wejścia -->
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Okrągły Avatar -->
                        <Grid Grid.Column="0" Width="56" Height="56" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <Ellipse Fill="#2D3748"/>
                            <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" 
                                  Fill="#A0AEC0" 
                                  Width="26" Height="26"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                            <Ellipse Width="56" Height="56">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{Binding ProfilePicture, Converter={StaticResource ByteToImageConverter}}" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                            <!-- Imię i Nazwisko -->
                            <TextBlock Text="{Binding ClientName}" FontSize="18" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI"/>
                            
                            <!-- Rola i Status -->
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Border CornerRadius="4" Padding="6,2" BorderThickness="1" 
                                        Background="{Binding ClientRoleBackground}" 
                                        BorderBrush="{Binding ClientRoleBorderBrush}"
                                        HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ClientRole}" Foreground="{Binding ClientRoleForeground}" FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"/>
                                </Border>

                                <Border CornerRadius="4" Background="#1E293B" Padding="6,2" Margin="6,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6" Height="6" Fill="{Binding ClientStatusBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding ClientStatusText}" FontSize="10" Foreground="White" FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Height="1" Background="#2D3748" Margin="0,12"/>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="AKTYWNE OFERTY (KARNETY)" FontSize="10" FontWeight="Bold" Foreground="#88FFFFFF" FontFamily="Segoe UI" Margin="0,0,0,8"/>

                        <!-- Lista aktywnych ofert -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ActiveOffers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1A1F26"
                                                BorderBrush="#2D3748"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10,8"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="12"
                                                           FontFamily="Segoe UI"/>
                                                <TextBlock Text="{Binding ValidityText}"
                                                           Foreground="#A0AEC0"
                                                           FontSize="11"
                                                           FontFamily="Segoe UI"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- 4. Przyciski sterujące na dole -->
        <Grid Grid.Row="3" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Przycisk Wpuszczenia Klienta -->
            <Button x:Name="RegisterEntranceButton" 
                    Grid.Column="0" 
                    Content="Wpuść klienta" 
                    Style="{StaticResource PrimaryButton}" 
                    Visibility="{Binding ClientCardVisibility}" 
                    Command="{Binding RegisterEntranceCommand}"
                    Margin="0,0,10,0"/>

            <!-- Przycisk Ponownego Skanowania -->
            <Button x:Name="ResumeButton" 
                    Grid.Column="1" 
                    Content="Zeskanuj ponownie" 
                    Style="{StaticResource SecondaryButton}" 
                    Visibility="{Binding ResumeButtonVisibility}" 
                    Command="{Binding ResumeScanningCommand}"
                    Margin="0,0,10,0"/>

            <Button Grid.Column="2" 
                    Content="Zamknij" 
                    Style="{StaticResource SecondaryButton}" 
                    Width="100" 
                    Click="CloseButton_Click"/>
        </Grid>
    </Grid>
</Window>
