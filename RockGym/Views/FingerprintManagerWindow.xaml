<Window x:Class="RockGym.Views.FingerprintManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RockGym.Views"
        xmlns:services="clr-namespace:RockGym.Services"
        mc:Ignorable="d"
        Title="Zarządzanie odciskami palców" 
        Height="500" 
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#111622"
        Foreground="White">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <services:ByteToImageConverter x:Key="ByteToImageConverter"/>

        <!-- Styl bazowy dla przycisków -->
        <Style x:Key="ManagerButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                Padding="15,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ManagerButton}">
            <Setter Property="Background" Value="#FF7F3F"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF945B"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#2D3748"/>
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ManagerButton}">
            <Setter Property="Background" Value="#2D3748"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A5568"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Styl dla przycisku usuwania -->
        <Style x:Key="DeleteActionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="#FF5B5B"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Nagłówek i status -->
            <RowDefinition Height="*"/>    <!-- Lista odcisków -->
            <RowDefinition Height="Auto"/> <!-- Dolne przyciski -->
        </Grid.RowDefinitions>

        <!-- 1. Nagłówek -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Zarządzanie odciskami palców" FontSize="18" FontWeight="Bold" Foreground="#FF7F3F" FontFamily="Segoe UI"/>
            <TextBlock Text="{Binding ClientName, FallbackValue='Klient', StringFormat='Klient: {0}'}" FontSize="13" Foreground="White" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
            <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#88FFFFFF" FontFamily="Segoe UI" Margin="0,2,0,0"/>
            <!-- Separator -->
            <Border Height="1" Background="#2D3748" Margin="0,10,0,0"/>
        </StackPanel>

        <!-- 2. Lista zarejestrowanych odcisków -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <!-- Pusty stan, gdy brak odcisków -->
            <TextBlock Text="Brak zarejestrowanych odcisków palców dla tego użytkownika." 
                       Foreground="#88FFFFFF" 
                       FontSize="13" 
                       FontStyle="Italic"
                       FontFamily="Segoe UI"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       Margin="20">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Fingerprints.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- ScrollViewer i ItemsControl z listą -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Fingerprints.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                
                <ItemsControl ItemsSource="{Binding Fingerprints}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1A1F26" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/> <!-- Miniatura -->
                                        <ColumnDefinition Width="*"/>    <!-- Szczegóły -->
                                        <ColumnDefinition Width="Auto"/> <!-- Usuń -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Miniatura odcisku -->
                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="4" ClipToBounds="True" Background="#111622" VerticalAlignment="Center">
                                        <Image Source="{Binding FingerprintImage, Converter={StaticResource ByteToImageConverter}}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>

                                    <!-- Informacje -->
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FormattedDate, StringFormat='Zarejestrowano: {0}'}" Foreground="White" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                        <TextBlock Text="{Binding FingerprintHash, StringFormat='Hash: {0}'}" Foreground="#A0AEC0" FontSize="10" FontFamily="Consolas" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Przycisk usuwania -->
                                    <Button Grid.Column="2" 
                                            Content="🗑" 
                                            Style="{StaticResource DeleteActionButton}"
                                            ToolTip="Usuń odcisk"
                                            Command="{Binding DataContext.DeleteFingerprintCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- 3. Dolne przyciski -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" 
                    Content="DODAJ NOWY ODCISK" 
                    Style="{StaticResource PrimaryButton}" 
                    Command="{Binding AddFingerprintCommand}"
                    IsEnabled="{Binding CanAdd}"
                    Margin="0,0,10,0"/>

            <Button Grid.Column="1" 
                    Content="Zamknij" 
                    Style="{StaticResource SecondaryButton}" 
                    Click="CloseButton_Click"/>
        </Grid>
    </Grid>
</Window>
