<Window x:Class="RockGym.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RockGym"
        xmlns:vm="clr-namespace:RockGym.ViewModels"
        xmlns:views="clr-namespace:RockGym.Views"
        mc:Ignorable="d"
        Title="Rock Gym - Panel Zarządzania" 
        Height="768" 
        Width="1024"
        MinWidth="1024"
        MinHeight="720"
        WindowState="Maximized">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <DataTemplate DataType="{x:Type vm:CustomersViewModel}">
            <views:CustomersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TransactionsViewModel}">
            <views:TransactionsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OffersViewModel}">
            <views:OffersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EventsViewModel}">
            <views:EventsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NotificationsViewModel}">
            <views:NotificationsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SummaryViewModel}">
            <views:SummaryView/>
        </DataTemplate>

        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0AEC0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="25,14"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="4,0,0,0"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2D3748"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF7F3F"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogoutButton" TargetType="Button">
            <Setter Property="Background" Value="#2D191E"/>
            <Setter Property="Foreground" Value="#FF6B6B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#44FF5B5B"/>
            <Setter Property="Padding" Value="0,12"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="8*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#111622">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,30,0,15" HorizontalAlignment="Center">
                <Image Source="pack://application:,,,/Assets/logo.png" 
                       Height="70" 
                       Width="300"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>

                <TextBlock Text="ZALOGOWANY JAKO" 
                           FontSize="11" 
                           FontWeight="Bold" 
                           Foreground="#FFFFFFFF" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,4"/>
                
                <TextBlock Text="{Binding LoggedInUserName}" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="#FF7F3F" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,15"/>

                <Border Height="1.5" Width="180" Background="#2D3748" HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,10,0,0">
                <Button Style="{StaticResource SidebarButton}" 
                        Content="KLIENCI" 
                        Command="{Binding ShowCustomersCommand}"/>
                
                <Button Style="{StaticResource SidebarButton}" 
                        Content="TRANSAKCJE" 
                        Command="{Binding ShowTransactionsCommand}"
                        Margin="0,2,0,0"/>
                
                <Button Style="{StaticResource SidebarButton}" 
                        Content="OFERTY" 
                        Command="{Binding ShowOffersCommand}"
                        Margin="0,2,0,0"/>
                
                <Button Style="{StaticResource SidebarButton}" 
                        Content="WYDARZENIA" 
                        Command="{Binding ShowEventsCommand}"
                        Margin="0,2,0,0"/>
                
                <Button Style="{StaticResource SidebarButton}" 
                        Content="POWIADOMIENIA" 
                        Command="{Binding ShowNotificationsCommand}"
                        Margin="0,2,0,0"/>

                <Button Style="{StaticResource SidebarButton}" 
                        Content="PODSUMOWANIE" 
                        Command="{Binding ShowSummaryCommand}"
                        Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"
                        Margin="0,2,0,0"/>

                <Button Style="{StaticResource SidebarButton}" 
                        Content="SKANER QR" 
                        Command="{Binding OpenScannerCommand}"
                        Margin="0,2,0,0"/>

                <Button Style="{StaticResource SidebarButton}" 
                        Content="SKANER ODCISKÓW" 
                        Command="{Binding OpenFingerprintScannerCommand}"
                        Margin="0,2,0,0"/>
            </StackPanel>

            <Button Grid.Row="2"
                    Style="{StaticResource LogoutButton}" 
                    Content="WYLOGUJ SIĘ" 
                    Command="{Binding LogoutCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Margin="15,0,15,25"/>
        </Grid>

        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Style.Triggers>
                        <Trigger Property="Content" Value="{x:Null}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ContentControl">
                                        <Grid>
                                            <Grid.Background>
                                                <ImageBrush ImageSource="pack://application:,,,/Assets/main-wall.jpg" Stretch="UniformToFill"/>
                                            </Grid.Background>
                                            
                                            <Grid Background="#7F222529">
                                                <TextBlock Text="WYBIERZ OPCJĘ" 
                                                           Foreground="#80FFFFFF" 
                                                           FontSize="24" 
                                                           FontWeight="Bold" 
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"
                                                           FontFamily="Segoe UI"/>
                                            </Grid>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>
    </Grid>
</Window>