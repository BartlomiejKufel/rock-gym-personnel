<Window x:Class="RockGym.Views.QrScannerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RockGym.Views"
        mc:Ignorable="d"
        Title="Skaner Kodów QR" 
        Height="720" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#111622"
        Foreground="White">

    <Window.Resources>
        <Style x:Key="ScannerButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                Padding="15,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ScannerButton}">
            <Setter Property="Background" Value="#FF7F3F"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF945B"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ScannerButton}">
            <Setter Property="Background" Value="#2D3748"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A5568"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScannerComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#1A1F26"/>
            <Setter Property="BorderBrush" Value="#2D3748"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border x:Name="border"
                                    Grid.ColumnSpan="2"
                                    CornerRadius="6"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    SnapsToDevicePixels="True"/>
                            
                            <ContentPresenter Grid.Column="0"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            
                            <ToggleButton x:Name="toggleButton"
                                          Grid.Column="1"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <TextBlock Text="▼" 
                                                       Foreground="#88FFFFFF" 
                                                       FontSize="8" 
                                                       HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   Grid.ColumnSpan="2"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="200">
                                    <Border x:Name="DropDownBorder"
                                            Background="#1A1F26"
                                            BorderBrush="#2D3748"
                                            BorderThickness="1.5"
                                            CornerRadius="6"
                                            Margin="0,2,0,0">
                                        <ScrollViewer Margin="4" SnapsToDevicePixels="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF7F3F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="border"
                                CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2D3748"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF7F3F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="280"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Skaner Kodów QR" FontSize="18" FontWeight="Bold" Foreground="#FF7F3F" FontFamily="Segoe UI"/>
                <TextBlock Text="Zeskanuj kod kamerą lub wybierz z pliku" FontSize="11" Foreground="#88FFFFFF" FontFamily="Segoe UI" Margin="0,2,0,0"/>
            </StackPanel>
            
            <ComboBox x:Name="CameraComboBox" 
                      Grid.Column="1" 
                      Style="{StaticResource ScannerComboBox}" 
                      Width="140" 
                      VerticalAlignment="Center"
                      SelectionChanged="CameraComboBox_SelectionChanged"/>

            <Button x:Name="BrowseFileButton"
                    Grid.Column="2"
                    Content="Z pliku..."
                    Style="{StaticResource SecondaryButton}"
                    Width="90"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Click="BrowseFileButton_Click"/>
        </Grid>

        <Border Grid.Row="1" Background="Black" CornerRadius="8" BorderBrush="#2D3748" BorderThickness="2" ClipToBounds="True">
            <Grid>
                <Image x:Name="CameraPreview" Stretch="UniformToFill"/>
                
                <Grid x:Name="ScannerOverlay">
                    <Border BorderBrush="#7FFF7F3F" BorderThickness="1" Margin="60" CornerRadius="12">
                        <Grid>
                            <Path Data="M0,20 L0,0 L20,0" Stroke="#FF7F3F" StrokeThickness="4" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            <Path Data="M0,0 L20,0 L20,20" Stroke="#FF7F3F" StrokeThickness="4" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,-2,0"/>
                            <Path Data="M0,20 L0,0 L20,0" Stroke="#FF7F3F" StrokeThickness="4" HorizontalAlignment="Left" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                     <ScaleTransform ScaleY="-1"/>
                                </Path.RenderTransform>
                            </Path>
                            <Path Data="M0,0 L20,0 L20,20" Stroke="#FF7F3F" StrokeThickness="4" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-2,0" RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <ScaleTransform ScaleY="-1"/>
                                </Path.RenderTransform>
                            </Path>
                        </Grid>
                    </Border>
                </Grid>

                <Border x:Name="PauseOverlay" Background="#CC111622" Visibility="{Binding PauseOverlayVisibility}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="PauseStatusTextBlock" Text="{Binding PauseStatusText}" Foreground="{Binding PauseStatusForeground}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="PauseSubStatusTextBlock" Text="{Binding PauseSubStatusText}" Foreground="#88FFFFFF" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,15,0,15">
            <Border x:Name="EmptyCard" Background="#1A1F26" BorderBrush="#2D3748" BorderThickness="1.5" CornerRadius="8" Padding="20" Visibility="{Binding EmptyCardVisibility}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="📷" FontSize="36" HorizontalAlignment="Center"/>
                    <TextBlock Text="Oczekiwanie na kod QR..." Foreground="#A0AEC0" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,10,0,0" FontFamily="Segoe UI"/>
                    <TextBlock Text="Umieść kod w polu widzenia kamery lub wczytaj obraz z pliku" Foreground="#60FFFFFF" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0" FontFamily="Segoe UI" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border x:Name="ClientCard" Background="#1A1F26" BorderBrush="#2D3748" BorderThickness="1.5" CornerRadius="8" Padding="15" Visibility="{Binding ClientCardVisibility}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Width="56" Height="56" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <Ellipse Fill="#2D3748"/>
                            <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" 
                                  Fill="#A0AEC0" 
                                  Width="26" Height="26"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                            <Ellipse Width="56" Height="56">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{Binding ProfilePicture, Converter={StaticResource ByteToImageConverter}}" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock Text="{Binding ClientName}" FontSize="18" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI"/>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Border CornerRadius="4" Padding="6,2" BorderThickness="1" 
                                        Background="{Binding ClientRoleBackground}" 
                                        BorderBrush="{Binding ClientRoleBorderBrush}"
                                        HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ClientRole}" Foreground="{Binding ClientRoleForeground}" FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"/>
                                </Border>

                                <Border CornerRadius="4" Background="#1E293B" Padding="6,2" Margin="6,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6" Height="6" Fill="{Binding ClientStatusBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding ClientStatusText}" FontSize="10" Foreground="White" FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Height="1" Background="#2D3748" Margin="0,12"/>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="AKTYWNE OFERTY (KARNETY)" FontSize="10" FontWeight="Bold" Foreground="#88FFFFFF" FontFamily="Segoe UI" Margin="0,0,0,8"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ActiveOffers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1A1F26"
                                                BorderBrush="#2D3748"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10,8"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="12"
                                                           FontFamily="Segoe UI"/>
                                                <TextBlock Text="{Binding ValidityText}"
                                                           Foreground="#A0AEC0"
                                                           FontSize="11"
                                                           FontFamily="Segoe UI"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="ResumeButton" 
                    Grid.Column="0" 
                    Content="Zeskanuj ponownie" 
                    Style="{StaticResource PrimaryButton}" 
                    Visibility="{Binding ResumeButtonVisibility}" 
                    Command="{Binding ResumeScanningCommand}"
                    Margin="0,0,10,0"/>

            <Button Grid.Column="1" 
                    Content="Zamknij" 
                    Style="{StaticResource SecondaryButton}" 
                    Width="100" 
                    Click="CloseButton_Click"/>
        </Grid>
    </Grid>
</Window>