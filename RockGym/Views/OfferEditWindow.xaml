<Window x:Class="RockGym.Views.OfferEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Oferta" 
        Height="420" 
        Width="450"
        MinWidth="450"
        MinHeight="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#111622"
        Foreground="White">

    <Window.Resources>
        <Style x:Key="DialogTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1F26"/>
            <Setter Property="BorderBrush" Value="#2D3748"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="#FF7F3F"/>
            <Setter Property="SelectionBrush" Value="#4A5568"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF7F3F"/>
                                <Setter TargetName="border" Property="Background" Value="#252B36"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF7F3F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SaveButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="#FF7F3F"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF945B"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CancelButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="#2D3748"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A5568"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderTextBlock"
                   Text="Dodaj ofertę"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#FF7F3F"
                   Margin="0,0,0,25"
                   FontFamily="Segoe UI"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="NAZWA OFERTY" FontSize="10" FontWeight="Bold" Foreground="#88FFFFFF" Margin="0,0,0,6"/>
            <TextBox x:Name="NameTextBox" Style="{StaticResource DialogTextBox}" Margin="0,0,0,18"/>

            <TextBlock Text="CENA (ZŁ)" FontSize="10" FontWeight="Bold" Foreground="#88FFFFFF" Margin="0,0,0,6"/>
            <TextBox x:Name="PriceTextBox" Style="{StaticResource DialogTextBox}" Margin="0,0,0,18"/>

            <TextBlock Text="CZAS TRWANIA (W DNIACH)" FontSize="10" FontWeight="Bold" Foreground="#88FFFFFF" Margin="0,0,0,6"/>
            <TextBox x:Name="DurationTextBox" Style="{StaticResource DialogTextBox}" Margin="0,0,0,18"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Style="{StaticResource CancelButton}" Content="Anuluj" Click="CancelButton_Click" Margin="0,0,10,0" Height="30" Width="90"/>
            <Button Style="{StaticResource SaveButton}" Content="Zapisz" Click="SaveButton_Click" Width="110" Height="30"/>
        </StackPanel>
    </Grid>
</Window>